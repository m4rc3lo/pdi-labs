{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ucrt64-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "PDI_BUILD_TESTS": true,
        "PDI_BUILD_DOCS": false,
        "PDI_BUILD_EXAMPLES": true,
        "PDI_FETCH_TEST_DEPENDENCIES": true
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "ucrt64-debug",
      "displayName": "MSYS2 UCRT64 Debug",
      "description": "Debug build with the compiler and OpenCV available in MSYS2 UCRT64.",
      "inherits": "ucrt64-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ucrt64-release",
      "displayName": "MSYS2 UCRT64 Release",
      "description": "Release build with the compiler and OpenCV available in MSYS2 UCRT64.",
      "inherits": "ucrt64-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ucrt64-debug",
      "configurePreset": "ucrt64-debug"
    },
    {
      "name": "ucrt64-release",
      "configurePreset": "ucrt64-release"
    }
  ]
}
